<Project>
  <PropertyGroup>
    <AzureBlobStorageExtensionFolderName>AzureBlobStorage</AzureBlobStorageExtensionFolderName>
    <AzureBlobStorageProjectPath>$(RepoRoot)src\Extensions\AzureBlobStorage\AzureBlobStorage.csproj</AzureBlobStorageProjectPath>
    <AzureBlobStoragePublishTargetFramework>$(LatestToolTargetFramework)</AzureBlobStoragePublishTargetFramework>
    <AzureBlobStoragePublishTargetFramework Condition="'$(TargetFramework)' != ''">$(TargetFramework)</AzureBlobStoragePublishTargetFramework>
    <AzureBlobStoragePublishRootPath>$(ArtifactsDir)pub\dotnet-monitor-egress-azureblobstorage\$(Configuration)\</AzureBlobStoragePublishRootPath>
    <AzureBlobStoragePlatformSpecificPublishPath>$(AzureBlobStoragePublishRootPath)$(AzureBlobStoragePublishTargetFramework)\$(PackageRid)\</AzureBlobStoragePlatformSpecificPublishPath>
    <!-- Self-contained, single-file, trimmed publish output (consumed by the dotnet-monitor-selfcontained package).
         The RuntimeIdentifier is part of the path so each RID gets its own publish directory. -->
    <AzureBlobStorageSelfContainedPublishPath>$(AzureBlobStoragePublishRootPath)$(AzureBlobStoragePublishTargetFramework)\selfcontained\$(RuntimeIdentifier)\</AzureBlobStorageSelfContainedPublishPath>
  </PropertyGroup>
  <!-- Framework-dependent publish flavors (the default dotnet-monitor package). Disabled when building the
       self-contained tool so its inner per-RID builds only produce the self-contained extension outputs. -->
  <ItemGroup Condition="'$(DotNetMonitorBuildSelfContainedTool)' != 'true'">
    <ProjectToPublish Include="$(AzureBlobStorageProjectPath)">
      <AdditionalProperties>TargetFramework=$(AzureBlobStoragePublishTargetFramework);RuntimeIdentifier=$(PackageRid);PublishDir=$(AzureBlobStoragePlatformSpecificPublishPath);SelfContained=false;UseAppHost=false</AdditionalProperties>
    </ProjectToPublish>
  </ItemGroup>
  <ItemGroup Condition="'$(DotNetMonitorBuildSelfContainedTool)' != 'true' and '$(SkipPlatformNeutralPublish)' != 'true'">
    <ProjectToPublish Include="$(AzureBlobStorageProjectPath)">
      <AdditionalProperties>TargetFramework=$(LatestToolTargetFramework);RuntimeIdentifier=;PublishDir=$(AzureBlobStoragePublishRootPath)$(LatestToolTargetFramework)\any\;SelfContained=false;UseAppHost=false</AdditionalProperties>
    </ProjectToPublish>
  </ItemGroup>
  <!-- Self-contained, single-file, fully-trimmed publish flavor for the current RID. Reflection-based JSON and
       configuration binding are used (consistent with the host) so they keep working under trimming; the
       reflected-over type sets are preserved via TrimmerRootAssembly items in SelfContainedExtension.targets.
       SuppressTrimAnalysisWarnings stays off (fail-fast) and TrimmerSingleWarn is off so every warning is
       reported in detail (nothing hides behind an IL2104 rollup); our own warnings are addressed with
       attributes (see EgressHelper [DynamicallyAccessedMembers] and GlobalSuppressions.SelfContainedTrim.cs).
       The Roslyn trim/single-file/AOT analyzers stay off because rooting is a link-time concept they cannot
       see. DotNetMonitorBuildSelfContainedTool is forwarded explicitly because PublishProjects.targets sets an
       explicit Properties set, so the inner build does not otherwise inherit the outer toggle. -->
  <ItemGroup Condition="'$(DotNetMonitorBuildSelfContainedTool)' == 'true' and '$(RuntimeIdentifier)' != ''">
    <ProjectToPublish Include="$(AzureBlobStorageProjectPath)">
      <AdditionalProperties>TargetFramework=$(AzureBlobStoragePublishTargetFramework);RuntimeIdentifier=$(RuntimeIdentifier);PublishDir=$(AzureBlobStorageSelfContainedPublishPath);SelfContained=true;PublishSingleFile=true;PublishTrimmed=true;TrimMode=full;UseAppHost=true;JsonSerializerIsReflectionEnabledByDefault=true;EnableConfigurationBindingGenerator=false;SuppressTrimAnalysisWarnings=false;TrimmerSingleWarn=false;EnableTrimAnalyzer=false;EnableSingleFileAnalyzer=false;EnableAotAnalyzer=false;DotNetMonitorBuildSelfContainedTool=true</AdditionalProperties>
    </ProjectToPublish>
  </ItemGroup>
</Project>
